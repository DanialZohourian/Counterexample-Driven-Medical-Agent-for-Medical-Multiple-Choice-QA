# OpenAI-compatible endpoint (OpenAI, OpenRouter, etc.)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=YOUR_KEY
LLM_MODEL=anthropic/claude-3.5-sonnet

# Best-effort JSON mode (if provider supports response_format json_object)
LLM_USE_JSON_MODE=false

# Determinism defaults
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=700
LLM_TIMEOUT_S=60
LLM_MAX_RETRIES=4

# Concurrency for eval
EVAL_CONCURRENCY=4

# Storage
RUNS_DIR=./runs
DATA_DIR=./data
